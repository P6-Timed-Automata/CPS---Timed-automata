<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE nta PUBLIC '-//Uppaal Team//DTD Flat System 1.6//EN'
  'http://www.it.uu.se/research/group/darts/uppaal/flat-1_6.dtd'>
<nta>
  <declaration>clock cl; int temp; const int a = 2010; const int b = 2193;</declaration>
  <template>
    <name>TagModel</name>
    <declaration></declaration>
    <location id="id0" x="223" y="-754">
      <name x="223" y="-774">S0</name>
      <label kind="invariant" cl="223" y="-734">cl &lt;= 86100</label>
    </location>
    <location id="id1" x="223" y="-162">
      <name x="223" y="-182">S88</name>
      <label kind="invariant" cl="223" y="-142">cl &lt;= 82500</label>
    </location>
    <init ref="id0"/>
    <transition>
      <source ref="id0"/>
      <target ref="id0"/>
      <label kind="guard">cl &gt;= 0 &amp;&amp; cl &lt;= 86100</label>
      <label kind="assignment">temp = 2193, cl = 0</label>
    </transition>
    <transition>
      <source ref="id0"/>
      <target ref="id1"/>
      <label kind="guard">cl &gt;= 26100 &amp;&amp; cl &lt;= 26100</label>
      <label kind="assignment">temp = 2010, cl = 0</label>
    </transition>
    <transition>
      <source ref="id1"/>
      <target ref="id1"/>
      <label kind="guard">cl &gt;= 26400 &amp;&amp; cl &lt;= 82500</label>
      <label kind="assignment">temp = 2193, cl = 0</label>
    </transition>
  </template>
  <system>Process = TagModel(); system Process;</system>
  <queries>
    <query>
      <formula>simulate [&lt;=18000] { temp }</formula>
      <comment/>
    </query>
  </queries>
</nta>