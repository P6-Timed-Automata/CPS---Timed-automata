<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE nta PUBLIC '-//Uppaal Team//DTD Flat System 1.6//EN'
  'http://www.it.uu.se/research/group/darts/uppaal/flat-1_6.dtd'>
<nta>
  <declaration>clock cl; int temp; const int 0 = a; const int 1 = b; const int 2 = c; const int 3 = d;</declaration>
  <template>
    <name>TagModel</name>
    <declaration></declaration>
    <location id="id0" x="217" y="-680">
      <name x="217" y="-700">S0</name>
      <label kind="invariant" cl="217" y="-660">cl &lt;= 9600</label>
    </location>
    <location id="id1" x="217" y="-137">
      <name x="217" y="-157">S7</name>
      <label kind="invariant" cl="217" y="-117">cl &lt;= 2584050</label>
    </location>
    <init ref="id0"/>
    <transition>
      <source ref="id0"/>
      <target ref="id0"/>
      <label kind="guard">cl &gt;= 600 &amp;&amp; cl &lt;= 8100</label>
      <label kind="assignment">temp = 0, cl = 0</label>
    </transition>
    <transition>
      <source ref="id0"/>
      <target ref="id1"/>
      <label kind="guard">cl &gt;= 9600 &amp;&amp; cl &lt;= 9600</label>
      <label kind="assignment">temp = 0, cl = 0</label>
    </transition>
    <transition>
      <source ref="id1"/>
      <target ref="id1"/>
      <label kind="guard">cl &gt;= 11100 &amp;&amp; cl &lt;= 2525250</label>
      <label kind="assignment">temp = 0, cl = 0</label>
    </transition>
    <transition>
      <source ref="id1"/>
      <target ref="id1"/>
      <label kind="guard">cl &gt;= 30600 &amp;&amp; cl &lt;= 2567250</label>
      <label kind="assignment">temp = 0, cl = 0</label>
    </transition>
    <transition>
      <source ref="id1"/>
      <target ref="id1"/>
      <label kind="guard">cl &gt;= 14100 &amp;&amp; cl &lt;= 2584050</label>
      <label kind="assignment">temp = 0, cl = 0</label>
    </transition>
    <transition>
      <source ref="id1"/>
      <target ref="id1"/>
      <label kind="guard">cl &gt;= 29100 &amp;&amp; cl &lt;= 2576850</label>
      <label kind="assignment">temp = 0, cl = 0</label>
    </transition>
  </template>
  <system>Process = TagModel(); system Process;</system>
  <queries>
    <query>
      <formula>simulate [&lt;=18000] { temp }</formula>
      <comment/>
    </query>
  </queries>
</nta>