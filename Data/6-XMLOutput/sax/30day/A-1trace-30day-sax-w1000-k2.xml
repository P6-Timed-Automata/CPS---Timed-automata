<nta>
  <declaration>clock cl; int temp; const int 0 = a; const int 1 = b;</declaration>
  <template>
    <name>TagModel</name>
    <declaration></declaration>
    <location id="id0" x="217" y="-137">
      <name x="217" y="-157">S0</name>
      <label kind="invariant" cl="217" y="-117">cl &lt;= 2583450</label>
    </location>
    <init ref="id0"/>
    <transition>
      <source ref="id0"/>
      <target ref="id0"/>
      <label kind="guard">cl &gt;= 1200 &amp;&amp; cl &lt;= 2583450</label>
      <label kind="assignment">temp = 0, cl = 0</label>
    </transition>
    <transition>
      <source ref="id0"/>
      <target ref="id0"/>
      <label kind="guard">cl &gt;= 30900 &amp;&amp; cl &lt;= 2576250</label>
      <label kind="assignment">temp = 0, cl = 0</label>
    </transition>
  </template>
  <system>Process = TagModel(); system Process;</system>
  <queries>
    <query>
      <formula>simulate [&lt;=18000] { temp }</formula>
      <comment/>
    </query>
  </queries>
</nta>