<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE nta PUBLIC '-//Uppaal Team//DTD Flat System 1.6//EN'
  'http://www.it.uu.se/research/group/darts/uppaal/flat-1_6.dtd'>
<nta>
  <declaration>clock t; int temp; const int a = 2195;</declaration>
  <template>
    <name>TagModel</name>
    <declaration></declaration>
    <location id="id0" x="309" y="-1767">
      <name x="309" y="-1787">S0</name>
      <label kind="invariant" t="309" y="-1747">t &lt;= 2</label>
    </location>
    <location id="id1" x="148" y="-1246">
      <name x="148" y="-1266">S1</name>
      <label kind="invariant" t="148" y="-1226">t &lt;= 1</label>
    </location>
    <location id="id2" x="481" y="-1246">
      <name x="481" y="-1266">S5</name>
      <label kind="invariant" t="481" y="-1226">t &lt;= 4</label>
    </location>
    <location id="id3" x="487" y="-702">
      <name x="487" y="-722">S2</name>
      <label kind="invariant" t="487" y="-682">t &lt;= 5</label>
    </location>
    <location id="id4" x="137" y="-702">
      <name x="137" y="-722">S4</name>
    </location>
    <location id="id5" x="487" y="-137">
      <name x="487" y="-157">S3</name>
    </location>
    <init ref="id0"/>
    <transition>
      <source ref="id0"/>
      <target ref="id1"/>
      <label kind="guard">t &gt;= 2 &amp;&amp; t &lt;= 2</label>
      <label kind="assignment">temp = 2195, t = 0</label>
    </transition>
    <transition>
      <source ref="id0"/>
      <target ref="id2"/>
      <label kind="guard">t &gt;= 1 &amp;&amp; t &lt;= 1</label>
      <label kind="assignment">temp = 2195, t = 0</label>
    </transition>
    <transition>
      <source ref="id1"/>
      <target ref="id4"/>
      <label kind="guard">t &gt;= 1 &amp;&amp; t &lt;= 1</label>
      <label kind="assignment">temp = 0, t = 0</label>
    </transition>
    <transition>
      <source ref="id2"/>
      <target ref="id3"/>
      <label kind="guard">t &gt;= 4 &amp;&amp; t &lt;= 4</label>
      <label kind="assignment">temp = 2195, t = 0</label>
    </transition>
    <transition>
      <source ref="id3"/>
      <target ref="id5"/>
      <label kind="guard">t &gt;= 5 &amp;&amp; t &lt;= 5</label>
      <label kind="assignment">temp = 0, t = 0</label>
    </transition>
  </template>
  <system>Process = TagModel(); system Process;</system>
  <queries>
    <query>
      <formula>simulate [&lt;=18000] { temp }</formula>
      <comment/>
    </query>
  </queries>
</nta>